# ============================================================
#  WatchScanner — Configurazione
#  Copia questo file in .env e compila i valori reali
# ============================================================

# --- Modalità sviluppo ---
# true  = dati mock (nessuna API key necessaria)
# false = scraping reale (richiede le chiavi sotto)
MOCK_MODE=true
DEBUG=false

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- OpenAI (Vision Agent) ---
# Ottieni la chiave su: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Instagram (Social Agent) ---
# Account Instagram da usare per la scansione.
# Consiglio: crea un account dedicato (non il tuo personale).
# Il sistema salva la sessione in instagram_session.json per ~90 giorni.
# Se hai 2FA attivo, disabilitalo per questo account.
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# --- Telegram (Alert Bot) ---
# 1. Scrivi a @BotFather su Telegram
# 2. Crea un nuovo bot con /newbot
# 3. Copia il token che ti dà
TELEGRAM_BOT_TOKEN=
# Il chat_id del tuo account (ottienilo da @userinfobot)
TELEGRAM_CHAT_ID=

# --- Apify (scraping avanzato) ---
# Opzionale, per siti JS-rendered. https://apify.com
APIFY_API_KEY=

# --- Rate limiting ---
SCRAPER_DELAY_SECONDS=2.0
MAX_RETRIES=3
REQUEST_TIMEOUT_SECONDS=15
